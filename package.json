{
  "name": "chrome-tabs-extension",
  "description": "A starter template for building browser extensions with Svelte 5, Tailwind 4, and WXT",
  "private": true,
  "version": "0.0.1",
  "keywords": [
    "wxt",
    "svelte",
    "svelte-5",
    "tailwind",
    "tailwind-4",
    "browser-extension",
    "firefox-extension",
    "extension"
  ],
  "scripts": {
    "dev": "wxt -b firefox --port=3004",
    "build": "wxt build -b firefox",
    "zip": "wxt zip -b firefox",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "postinstall": "wxt prepare",
    "clean": "git clean -fXd"
  },
  "dependencies": {
    "mode-watcher": "^1.1.0",
    "runed": "^0.37.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "6.2.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "4.1.18",
    "@tsconfig/svelte": "^5.0.6",
    "@types/chrome": "^0.1.32",
    "@wxt-dev/auto-icons": "^1.1.1",
    "@wxt-dev/module-svelte": "^2.0.4",
    "prettier": "^3.7.4",
    "prettier-plugin-svelte": "^3.4.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "5.46.1",
    "svelte-check": "^4.3.5",
    "tailwindcss": "4.1.18",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0",
    "wxt": "^0.20.13"
  },
  "overrides": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0-next"
  },
  "resolutions": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0-next"
  }
}
